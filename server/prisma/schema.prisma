generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum USER_ROLE {
  SUPER_ADMIN
  ADMIN
  ORGANIZER
  ATTENDEE
}

enum REGISTRATION_STATUS {
  PENDING
  CONFIRMED
  CANCELLED
}

enum EVENT_STATUS {
  DRAFT
  PUBLISHED
  CANCELLED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          USER_ROLE      @default(ATTENDEE)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  events        Event[]        @relation("OrganizerEvents")
  registrations Registration[]
  venues        Venue[]        @relation("VenueCreator")
  venueBookings VenueBooking[] @relation("VenueBookingCreator")
}

model Event {
  id             String         @id @default(uuid())
  title          String
  description    String?
  bannerImage    String?
  galleryImages  String[]
  category       String
  ticketPrice    Float          @default(0)
  startDate      DateTime
  endDate        DateTime
  startTime      String?
  endTime        String?
  attendeeLimit  Int
  venueId        String?
  organizerId    String
  status         EVENT_STATUS   @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organizer      User           @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Restrict)
  venue          Venue?         @relation(fields: [venueId], references: [id], onDelete: SetNull)
  venueBookings  VenueBooking[] @relation("EventVenueBookings")
  registrations  Registration[]

  @@index([organizerId])
  @@index([venueId])
  @@index([category])
  @@index([status])
  @@index([startDate, endDate])
}

model Registration {
  id        String              @id @default(cuid())
  userId    String
  eventId   String
  status    REGISTRATION_STATUS @default(PENDING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Venue {
  id          String   @id @default(cuid())
  name        String
  location    String
  address     String?
  capacity    Int
  description String?
  image       String?
  amenities   String[]
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User?    @relation("VenueCreator", fields: [createdById], references: [id], onDelete: SetNull)
  bookings    VenueBooking[]
  events      Event[]

  @@unique([name, location])
  @@index([location])
  @@index([capacity])
  @@index([isActive])
}

enum VENUE_BOOKING_STATUS {
  BOOKED
  CANCELLED
}

model VenueBooking {
  id          String               @id @default(cuid())
  venueId     String
  startDate   DateTime
  endDate     DateTime
  startTime   String?
  endTime     String?
  status      VENUE_BOOKING_STATUS @default(BOOKED)
  eventId     String?
  createdById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  venue       Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event       Event?               @relation("EventVenueBookings", fields: [eventId], references: [id], onDelete: SetNull)
  createdBy   User?                @relation("VenueBookingCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([venueId, startDate, endDate])
  @@index([status])
  @@index([eventId])
  @@index([createdById])
  @@unique([venueId, startDate, endDate, startTime, endTime])
}
